{
  "name": "@openreader/database",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "files": [
    "bin",
    "migrations",
    "src"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./migrate": "./src/migrate.mjs",
    "./schema": "./src/schema.ts",
    "./schema-postgres": "./src/schema_postgres.ts",
    "./schema-sqlite": "./src/schema_sqlite.ts",
    "./schema-auth-postgres": "./src/schema_auth_postgres.ts",
    "./schema-auth-sqlite": "./src/schema_auth_sqlite.ts",
